{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/connect",
      "destination": "/public/connect.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
